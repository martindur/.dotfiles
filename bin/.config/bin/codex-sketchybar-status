#!/usr/bin/env bash

set -u

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

JQ_BIN="$(command -v jq 2>/dev/null || true)"
WEZTERM_BIN="$(command -v wezterm 2>/dev/null || true)"
LSOF_BIN="$(command -v lsof 2>/dev/null || true)"
PS_BIN="$(command -v ps 2>/dev/null || true)"

if [ -z "$JQ_BIN" ] || [ -z "$WEZTERM_BIN" ] || [ -z "$LSOF_BIN" ] || [ -z "$PS_BIN" ]; then
  echo "[]"
  exit 0
fi

wezterm_json="$("$WEZTERM_BIN" cli list --format json 2>/dev/null || true)"
if [ -z "$wezterm_json" ] || [ "$wezterm_json" = "null" ]; then
  echo "[]"
  exit 0
fi

records_file="$(mktemp)"
trap 'rm -f "$records_file"' EXIT

parse_state() {
  local session_file="$1"
  tail -n 500 "$session_file" 2>/dev/null | awk '
    BEGIN {
      state = "idle";
      last_ts = "";
      pending_block_call_id = "";
    }
    {
      ts = "";
      current_call_id = "";
      if (match($0, /"timestamp":"[^"]*"/)) {
        ts = substr($0, RSTART + 13, RLENGTH - 14);
      }
      if (ts != "") {
        last_ts = ts;
      }

      if (match($0, /"call_id":"[^"]*"/)) {
        current_call_id = substr($0, RSTART + 11, RLENGTH - 12);
      }

      if (index($0, "\"type\":\"event_msg\"") > 0) {
        if (index($0, "\"payload\":{\"type\":\"exec_approval_request\"") > 0 ||
            index($0, "\"payload\":{\"type\":\"apply_patch_approval_request\"") > 0) {
          state = "blocked";
        } else if (index($0, "\"payload\":{\"type\":\"task_complete\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"turn_aborted\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"shutdown_complete\"") > 0) {
          state = "idle";
        } else if (index($0, "\"payload\":{\"type\":\"task_started\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"agent_reasoning\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"agent_message\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"agent_message_delta\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"exec_command_begin\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"item_started\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"patch_apply_begin\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"mcp_tool_call_begin\"") > 0 ||
                   index($0, "\"payload\":{\"type\":\"web_search_begin\"") > 0) {
          if (pending_block_call_id == "") {
            state = "working";
          }
        }
      } else if (index($0, "\"type\":\"response_item\"") > 0) {
        if (index($0, "\"payload\":{\"type\":\"function_call\",\"name\":\"exec_command\"") > 0 &&
            (index($0, "\"sandbox_permissions\":\"require_escalated\"") > 0 ||
             index($0, "\\\"sandbox_permissions\\\":\\\"require_escalated\\\"") > 0) &&
            current_call_id != "") {
          pending_block_call_id = current_call_id;
          state = "blocked";
        } else if (index($0, "\"payload\":{\"type\":\"function_call_output\"") > 0 &&
                   pending_block_call_id != "" &&
                   current_call_id == pending_block_call_id) {
          pending_block_call_id = "";
          state = "working";
        } else if (index($0, "\"payload\":{\"type\":\"function_call\"") > 0 ||
            index($0, "\"payload\":{\"type\":\"custom_tool_call\"") > 0 ||
            index($0, "\"payload\":{\"type\":\"web_search_call\"") > 0 ||
            index($0, "\"payload\":{\"type\":\"reasoning\"") > 0) {
          if (pending_block_call_id == "") {
            state = "working";
          }
        }
      }
    }
    END {
      printf "%s|%s\n", state, last_ts;
    }
  '
}

while IFS= read -r proc_line; do
  [ -z "$proc_line" ] && continue

  pid="$(printf '%s\n' "$proc_line" | awk '{print $1}')"
  tty="$(printf '%s\n' "$proc_line" | awk '{print $2}')"
  [ -z "$pid" ] && continue
  [ -z "$tty" ] && continue
  [ "$tty" = "??" ] && continue

  pane_json="$(printf '%s' "$wezterm_json" | "$JQ_BIN" -c --arg tty "/dev/$tty" '.[] | select(.tty_name == $tty) | . ' | head -n 1)"
  [ -z "$pane_json" ] && continue

  session_file="$("$LSOF_BIN" -p "$pid" 2>/dev/null | awk '/\/\.codex\/sessions\/.*\.jsonl$/ {print $NF}' | sort | tail -n 1)"
  [ -z "$session_file" ] && continue
  [ -f "$session_file" ] || continue

  state_and_ts="$(parse_state "$session_file")"
  state="${state_and_ts%%|*}"
  updated_at="${state_and_ts#*|}"

  case "$state" in
    blocked) state_rank=0 ;;
    working) state_rank=1 ;;
    *) state_rank=2 ;;
  esac

  workspace="$(printf '%s' "$pane_json" | "$JQ_BIN" -r '.workspace // ""')"
  cwd_uri="$(printf '%s' "$pane_json" | "$JQ_BIN" -r '.cwd // ""')"
  pane_id="$(printf '%s' "$pane_json" | "$JQ_BIN" -r '.pane_id // 0')"
  pane_active="$(printf '%s' "$pane_json" | "$JQ_BIN" -r '.is_active // false')"
  tty_name="$(printf '%s' "$pane_json" | "$JQ_BIN" -r '.tty_name // ""')"

  cwd="${cwd_uri#file://}"

  "$JQ_BIN" -cn \
    --arg pid "$pid" \
    --arg tty "$tty_name" \
    --arg workspace "$workspace" \
    --arg cwd "$cwd" \
    --arg pane_id "$pane_id" \
    --arg session_file "$session_file" \
    --arg state "$state" \
    --arg updated_at "$updated_at" \
    --argjson pane_active "$pane_active" \
    --argjson state_rank "$state_rank" \
    '{
      pid: ($pid | tonumber),
      tty: $tty,
      workspace: $workspace,
      cwd: $cwd,
      pane_id: ($pane_id | tonumber),
      session_file: $session_file,
      state: $state,
      updated_at: $updated_at,
      pane_active: $pane_active,
      state_rank: $state_rank
    }' >> "$records_file"
done < <("$PS_BIN" -axo pid=,tty=,command= | awk 'tolower($0) ~ /(^|[[:space:]\/])codex([[:space:]]|$)/ && tolower($0) !~ /codex-sketchybar-status/')

if [ ! -s "$records_file" ]; then
  echo "[]"
  exit 0
fi

"$JQ_BIN" -s 'sort_by(.state_rank, .pid) | map(del(.state_rank))' "$records_file"
